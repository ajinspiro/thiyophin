@model LibraryManagementSystem2_0.Models.CheckoutCreateViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container-fluid">
    <h2 class="mb-4">Checkout</h2>

    <div class="row mb-4">
        <div class="col-md-5 mb-3 mb-md-0">
            <form method="get" asp-action="Create">
                <div class="input-group">
                    <input type="text"
                           name="memberSearch"
                           value="@Model.MemberSearch"
                           class="form-control"
                           placeholder="Search user" />
                    <button type="submit" class="btn btn-dark">Search</button>
                    <a asp-action="Create" class="btn btn-outline-secondary">Clear</a>
                    <input type="hidden" name="bookSearch" value="@Model.BookSearch" />
                </div>
            </form>
        </div>

        <div class="col-md-5 mb-3 mb-md-0">
            <form method="get" asp-action="Create">
                <div class="input-group">
                    <input type="text"
                           name="bookSearch"
                           value="@Model.BookSearch"
                           class="form-control"
                           placeholder="Search book" />
                    <button type="submit" class="btn btn-dark">Search</button>
                    <a asp-action="Create" class="btn btn-outline-secondary">Clear</a>
                    <input type="hidden" name="memberSearch" value="@Model.MemberSearch" />
                </div>
            </form>
        </div>

        <div class="col-md-2 d-flex align-items-start justify-content-md-end mt-3 mt-md-0">
            <form asp-action="Create" method="post" class="w-100">
                <input type="hidden" asp-for="MemberSearch" />
                <input type="hidden" asp-for="BookSearch" />

                <div class="row">
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">User</label>
                        <select class="form-select" asp-for="SelectedMemberId" name="SelectedMemberId">
                            <option value="">Select member</option>
                            @foreach (var member in Model.Members)
                            {
                                <option value="@member.Id">@member.FullName</option>
                            }
                        </select>
                        <span asp-validation-for="SelectedMemberId" class="text-danger"></span>
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Book</label>
                        <select class="form-select" asp-for="SelectedBookId" name="SelectedBookId">
                            <option value="">Select book</option>
                            @foreach (var book in Model.Books)
                            {
                                <option value="@book.Id">@book.Title (@book.Isbn)</option>
                            }
                        </select>
                        <span asp-validation-for="SelectedBookId" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-grid">
                        <button type="submit" class="btn btn-dark">Checkout</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h5 class="mb-3">Members</h5>
            <ul class="list-unstyled">
                @foreach (var member in Model.Members)
                {
                    <li class="mb-1">@member.FullName</li>
                }
            </ul>
        </div>
        <div class="col-md-6">
            <h5 class="mb-3">Books</h5>
            <ul class="list-unstyled">
                @foreach (var book in Model.Books)
                {
                    <li class="mb-1">@book.Title</li>
                }
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

