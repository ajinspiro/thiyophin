@model IEnumerable<LibraryManagementSystem2_0.Models.Member>
@{
    ViewData["Title"] = "Members";
    var search = ViewBag.Search as string;
    var istZone = TimeZoneInfo.FindSystemTimeZoneById("Asia/Kolkata");
}

<div class="container-fluid">
    <h2 class="mb-4">Members</h2>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <form class="flex-grow-1 me-3" method="get">
            <div class="input-group">
                <input type="text"
                       name="search"
                       value="@search"
                       class="form-control"
                       placeholder="Search member" />
                <button type="submit" class="btn btn-dark">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>

        <a asp-action="Create" class="btn btn-secondary">Add</a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Joined on</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var member in Model)
            {
                var joinedUtc = DateTime.SpecifyKind(member.JoinedOn, DateTimeKind.Utc);
                var joinedIst = TimeZoneInfo.ConvertTimeFromUtc(joinedUtc, istZone);

                <tr>
                    <td>@member.FullName</td>
                    <td>@member.Phone</td>
                    <td>
                        @joinedIst.ToString("dd-MM-yyyy")<br />
                        <small class="text-muted">@joinedIst.ToString("HH:mm:ss")</small>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

