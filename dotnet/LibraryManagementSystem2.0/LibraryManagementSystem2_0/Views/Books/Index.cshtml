@model IEnumerable<LibraryManagementSystem2_0.Models.BookListItemViewModel>
@{
    ViewData["Title"] = "Books";
    var search = ViewBag.Search as string;
    var istZone = TimeZoneInfo.FindSystemTimeZoneById("Asia/Kolkata");
}

<div class="container-fluid">
    <h2 class="mb-4">Books</h2>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <form class="flex-grow-1 me-3" method="get">
            <div class="input-group">
                <input type="text"
                       name="search"
                       value="@search"
                       class="form-control"
                       placeholder="Search book" />
                <button type="submit" class="btn btn-dark">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>

        <a asp-action="Create" class="btn btn-secondary">Add</a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>ISBN</th>
                    <th>Added on</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var book in Model)
            {
                var statusClass = book.IsOut ? "text-danger" : "text-success";
                var statusText = book.IsOut ? "out" : "in";
                var addedUtc = DateTime.SpecifyKind(book.AddedOn, DateTimeKind.Utc);
                var addedIst = TimeZoneInfo.ConvertTimeFromUtc(addedUtc, istZone);

                <tr>
                    <td>@book.Title</td>
                    <td>@book.Isbn</td>
                    <td>
                        @addedIst.ToString("dd-MM-yyyy")<br />
                        <small class="text-muted">@addedIst.ToString("HH:mm:ss")</small>
                    </td>
                    <td class="@statusClass fw-bold">@statusText</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

