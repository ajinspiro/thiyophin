<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NuPhonesApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/common/base.css" />
    <link rel="stylesheet" href="~/css/common/header.css" />
    <link rel="stylesheet" href="~/css/accounts/signup.css" />
    <link rel="stylesheet" href="~/css/accounts/login.css" />
    <link rel="stylesheet" href="~/css/home/landing.css" />
</head>
<body>
    <div>
        @if (ViewData["HideHeader"] == null)
        {
            <partial name="_Header" />
        }
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>