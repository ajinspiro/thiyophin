@model NuPhonesApp.ViewModels.SignupViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["HideHeader"] = true;
    ViewData["Title"] = "Signup Page";
}

<div class="signup-container">
    <h1>NuPhones | Sign up</h1>

    <form asp-controller="Account" asp-action="Signup" method="post" class="signup-form">
        @Html.AntiForgeryToken()

        

        <div class="form-group">
            <label asp-for="FirstName">First name</label>
            <input asp-for="FirstName" />
            <span asp-validation-for="FirstName"></span>
        </div>

        <div class="form-group">
            <label asp-for="LastName">Last name</label>
            <input asp-for="LastName" />
            <span asp-validation-for="LastName"></span>
        </div>

        <div class="form-group">
            <label asp-for="UserName">Username</label>
            <input asp-for="UserName" />
            <span asp-validation-for="UserName"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" />
            <span asp-validation-for="Email"></span>
        </div>

        <div class="form-group">
            <label asp-for="Phone">Phone number</label>
            <input asp-for="Phone" />
            <span asp-validation-for="Phone"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Password</label>
            <input asp-for="Password" type="password" />
            <span asp-validation-for="Password"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword">Confirm password</label>
            <input asp-for="ConfirmPassword" type="password" />
            <span asp-validation-for="ConfirmPassword"></span>
        </div>
        <div asp-validation-summary="ModelOnly" class="error-message"></div>

        <button type="submit" class="create-account-btn">Create new account</button>

        <p class="already-text">
            Already have an account?
        </p>

        <!-- ✅ KEPT EXACTLY AS YOU WANTED -->
        <a asp-controller="Account" asp-action="Login" class="login-btn">Login</a>
    </form>
</div>

@section scripts{
    <partial name="_ValidationScriptsPartial" />
}